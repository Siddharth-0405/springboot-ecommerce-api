# ─── PostgreSQL Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=productdb
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ─── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Generate your own secret: must be at least 256 bits (64 hex characters)
JWT_SECRET=your_jwt_secret_key_here_must_be_64_characters_long_replace_this
JWT_EXPIRATION=86400000

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Step 1: Enable 2-Step Verification on your Google Account
# Step 2: Go to Google Account → Security → App Passwords → Generate
# Step 3: Use that 16-character code as MAIL_PASSWORD (NOT your real Gmail password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_character_app_password

# ─── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=default